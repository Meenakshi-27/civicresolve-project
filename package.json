{
  "name": "civic-resolve",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "backend": "node backend/server.js",
    "platform": "node backend/server.js",
    "dev:all": "concurrently \"npm run dev\" \"npm run backend\"",
    "build:portals": "tailwindcss -i ./src/index.css -o ./public/portals.css --content './frontend/stitch (1)/stitch/**/*.html'",
    "build": "vite build && npm run build:portals",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "compromise": "^14.15.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "vite": "^8.0.1"
  }
}
